# Pinata IPFS Configuration
# Get your JWT from: https://app.pinata.cloud/developers/api-keys
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_token_here

# Optional: Custom Pinata gateway (defaults to https://gateway.pinata.cloud)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# Algorand Configuration (for future smart contract integration)
NEXT_PUBLIC_ALGOD_SERVER=http://localhost:4001
NEXT_PUBLIC_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
NEXT_PUBLIC_INDEXER_SERVER=http://localhost:8980
